{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "NLP Sentiment Analysis — Azure Container Apps deployment"
  },
  "parameters": {
    "containerAppName": {
      "type": "string",
      "defaultValue": "nlp-sentiment",
      "metadata": { "description": "Name of the Container App" }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Azure region for all resources" }
    },
    "containerImage": {
      "type": "string",
      "metadata": { "description": "Full container image URL (registry/image:tag)" }
    },
    "containerRegistryServer": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "ACR login server (e.g. myregistry.azurecr.io)" }
    },
    "containerRegistryUsername": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "ACR admin username" }
    },
    "containerRegistryPassword": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": { "description": "ACR admin password" }
    },
    "appMode": {
      "type": "string",
      "defaultValue": "api",
      "allowedValues": ["api", "ui"],
      "metadata": { "description": "Launch mode: 'api' (FastAPI on 8000) or 'ui' (Gradio on 7860)" }
    },
    "targetPort": {
      "type": "int",
      "defaultValue": 8000,
      "metadata": { "description": "Container port to expose (8000 for API, 7860 for UI)" }
    }
  },
  "variables": {
    "environmentName": "[concat(parameters('containerAppName'), '-env')]",
    "workspaceName":   "[concat(parameters('containerAppName'), '-logs')]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[variables('workspaceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": { "name": "PerGB2018" },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2023-05-01",
      "name": "[variables('environmentName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]"
      ],
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))).customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName')), '2022-10-01').primarySharedKey]"
          }
        }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerAppName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', variables('environmentName'))]"
      ],
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('environmentName'))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": "[parameters('targetPort')]",
            "allowInsecure": false,
            "traffic": [{ "latestRevision": true, "weight": 100 }]
          },
          "registries": "[if(empty(parameters('containerRegistryServer')), json('[]'), createArray(createObject('server', parameters('containerRegistryServer'), 'username', parameters('containerRegistryUsername'), 'passwordSecretRef', 'registry-password')))]",
          "secrets": "[if(empty(parameters('containerRegistryPassword')), json('[]'), createArray(createObject('name', 'registry-password', 'value', parameters('containerRegistryPassword'))))]"
        },
        "template": {
          "containers": [
            {
              "name": "[parameters('containerAppName')]",
              "image": "[parameters('containerImage')]",
              "resources": {
                "cpu": 2,
                "memory": "4Gi"
              },
              "env": [
                { "name": "MODE",          "value": "[parameters('appMode')]" },
                { "name": "PORT",          "value": "[string(parameters('targetPort'))]" },
                { "name": "HF_HOME",       "value": "/tmp/hf_cache" },
                { "name": "NLTK_DATA",     "value": "/var/task/nltk_data" },
                { "name": "MPLCONFIGDIR",  "value": "/tmp/matplotlib" }
              ]
            }
          ],
          "scale": {
            "minReplicas": 0,
            "maxReplicas": 5,
            "rules": [
              {
                "name": "http-rule",
                "http": {
                  "metadata": { "concurrentRequests": "5" }
                }
              }
            ]
          }
        }
      }
    }
  ],
  "outputs": {
    "containerAppUrl": {
      "type": "string",
      "value": "[concat('https://', reference(resourceId('Microsoft.App/containerApps', parameters('containerAppName'))).configuration.ingress.fqdn)]"
    }
  }
}
